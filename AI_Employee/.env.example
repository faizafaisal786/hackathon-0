# ═══════════════════════════════════════════════════════════
# AI Employee — PLATINUM Tier Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# MINIMUM REQUIRED: set GROQ_API_KEY (free at console.groq.com)
# ═══════════════════════════════════════════════════════════

# ── FREE AI Backends (use at least one) ─────────────────────
# Groq: free at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# Gemini: free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_your_gemini_key_here

# Anthropic: PAID (optional fallback)
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Gmail (for real email sending) ──────────────────────────
# Use App Password (not your real password)
# Enable at: Google Account → Security → App Passwords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Telegram Notifications (optional) ───────────────────────
# Create bot at @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── WhatsApp via Twilio (optional) ──────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Twitter/X API (optional — for live posting) ─────────────
# Create app at: https://developer.twitter.com/en/portal/dashboard
# Requires: Free developer account → Create App → Keys & Tokens
TWITTER_BEARER_TOKEN=your_bearer_token_here
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here

# ── LinkedIn API (optional — for live posting) ──────────────
# Create app at: https://developer.linkedin.com/
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_ID=your_linkedin_person_id

# ── Loop Behavior ────────────────────────────────────────────
AUTO_APPROVE=false
LOOP_INTERVAL=60
MULTISTEP_AI=true

# ── PLATINUM Settings ────────────────────────────────────────
ENABLE_PLATINUM=true
ENABLE_MEMORY=true
ENABLE_SELF_IMPROVEMENT=true
IMPROVEMENT_INTERVAL=10
REVIEWER_THRESHOLD=7
MAX_TASK_FAILURES=3
